# AI Video Editor 환경 설정
# 이 파일을 복사해서 .env로 저장하고 실제 API 키를 입력하세요.
# cp .env.example .env

# Qwen/DashScope API 키 (영상 분석용)
# https://dashscope.console.aliyun.com/ 에서 발급
QWEN_API_KEY=your_qwen_api_key_here

# Anthropic API 키 (대본 생성용)
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=your_anthropic_api_key_here
