# Google Gemini API 키 (포즈 분석 리포트 생성)
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_Gemini_API_키_입력

# Anthropic Claude API 키 (숏폼 스크립트 생성)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=여기에_Anthropic_API_키_입력

# MediaPipe 포즈 모델 파일 경로
# 다운로드: https://developers.google.com/mediapipe/solutions/vision/pose_landmarker
POSE_MODEL_PATH=./pose_landmarker_heavy.task

# JWT 토큰 시크릿 키 (임의의 긴 문자열)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=여기에_랜덤_시크릿_키_입력
